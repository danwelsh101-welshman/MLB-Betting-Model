# edgr — environment variables TEMPLATE
#
# HOW TO USE:
#   1. Make a copy of this file named exactly ".env"
#   2. Fill in your real keys after the "=" signs
#   3. NEVER share your .env file or commit it to git (it holds secrets)
#
# The .env file is already listed in .gitignore so it stays private.

# --- The Odds API: REST data key (lets edgr READ odds to compute edges) ---
# Get a free key at https://the-odds-api.com  ("Get API Key")
ODDS_API_KEY=your_odds_api_key_here

# --- The Odds API: widget URL (DISPLAY-ONLY odds panel on the dashboard) ---
# Optional. Paste the full `src="..."` URL from an Odds API widget embed.
# This only shows odds; it does NOT feed edgr's edge calculations.
ODDS_WIDGET_URL=

# --- Optional settings (safe defaults are used if left blank) ---
# How edgr connects to its database. Default is a local SQLite file.
DATABASE_URL=sqlite:///data/processed/edgr.db

# Open-Meteo (weather) and the MLB Stats API are FREE and need NO key,
# so there is nothing to put here for them. They are listed for reference.
