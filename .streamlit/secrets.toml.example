# edgr — secrets template for Streamlit Community Cloud.
#
# Do NOT put real keys in a file you commit. Instead, copy these lines into
# your app's Settings -> Secrets panel on https://share.streamlit.io
# (or, for local use, create .streamlit/secrets.toml — it is git-ignored).

ODDS_API_KEY = "your_rest_api_key_here"
ODDS_WIDGET_URL = "https://widget.the-odds-api.com/v1/sports/baseball_mlb/events/?accessKey=YOUR_WIDGET_KEY&bookmakerKeys=fanduel&oddsFormat=american&markets=h2h%2Cspreads%2Ctotals"
